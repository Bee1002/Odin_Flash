<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <startup>
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
    </startup>
  <!--
    Tunables de velocidad LOKE (NO tocan Calculated Size ni GetCmdBuff).
    Cargados al arranque por LokePerformanceSettings.ApplyFromConfig().

    Problema original: Capa >= 128 usaba paquetes 256 KB + delay 3 ms por trozo
    (~34k ciclos write/ACK en ~8,5 GB) → flash ~18 min en SM-A326B.

    Mejoras aplicadas (referencia medida):
      SM-A326B Capa 128, 8,521 GB: ~17m 52s → ~08m 01s (32 particiones OK).
      SM-G950F Capa 64,  5,695 GB: Capa < 128 → LOKE/NAND 1 MiB, inter-partición 100 ms.

    Claves:
      Loke:HighCapaProfile             — auto | fast | balanced | safe (solo Capa >= 128).
      Loke:FlashAckDelayMsHighCapaMin  — ACK delay mínimo en Capa alta (auto/fast: 0).
      Loke:NandPacketBytesHighCapa     — paquete Capa >= 128 (default 512 KB).
      Loke:InterPartitionDelayMs       — pausa entre particiones (Capa >= 128, default 50).
      Loke:InterPartitionDelayMsLegacy — pausa entre particiones (Capa < 128, default 100).
      Loke:FlashChunkBytes             — paquete Capa < 128 / LOKE 0x64/5 (default 1 MiB).
      Serial:Read/WriteBufferSize      — buffers USB CDC (65536 OK en ambos perfiles).
      Ui:ProgressThrottleMs          — evita ~34k Dispatcher.Invoke por flash (0 = sin throttle).

    Perfiles Capa alta (Snapdragon / Exynos / MTK — mismo protocolo LOKE):
      auto     — 0 ms + 512 KB (default; A326B ~8 min). Si timeout en Capa 128 → balanced.
      fast     — igual que auto (claves de arriba).
      balanced — 1 ms + 512 KB (Qualcomm Capa 128 sensible, ej. A235M).
      safe     — 3 ms + 256 KB.

    Conexión serial (SerialConnectionSettings.ApplyFromConfig):
      Serial:Handshake              — None | RequestToSend (default) | XOnXOff | RequestToSendXOnXOff
      Serial:WakeToggleLowMs        — ms con DTR/RTS bajos antes del wake (default 100).
      Serial:WakeAfterLinesHighMs   — ms tras subir DTR/RTS antes de purgar RX/TX (default 500).
      Serial:OdinMagicReplyDelayMs  — ms tras magic ODIN antes de leer respuesta LOKE (default 400).

    Rollback global conservador: HighCapaProfile=safe, InterPartitionDelayMs=300,
      Serial buffers=4096, Ui:ProgressThrottleMs=0
  -->
  <appSettings>
    <add key="Loke:HighCapaProfile" value="auto" />
    <add key="Loke:FlashAckDelayMsHighCapaMin" value="0" />
    <add key="Loke:NandPacketBytesHighCapa" value="524288" />
    <add key="Loke:InterPartitionDelayMs" value="50" />
    <add key="Loke:InterPartitionDelayMsLegacy" value="100" />
    <add key="Serial:ReadBufferSize" value="65536" />
    <add key="Serial:WriteBufferSize" value="65536" />
    <add key="Serial:Handshake" value="RequestToSend" />
    <add key="Serial:WakeToggleLowMs" value="100" />
    <add key="Serial:WakeAfterLinesHighMs" value="500" />
    <add key="Serial:OdinMagicReplyDelayMs" value="400" />
    <add key="Ui:ProgressThrottleMs" value="250" />
  </appSettings>
  <runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <dependentAssembly>
        <assemblyIdentity name="System.Runtime.CompilerServices.Unsafe" publicKeyToken="b03f5f7f11d50a3a" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-6.0.3.0" newVersion="6.0.3.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="System.Memory" publicKeyToken="cc7b13ffcd2ddd51" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-4.0.5.0" newVersion="4.0.5.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="System.Buffers" publicKeyToken="cc7b13ffcd2ddd51" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-4.0.5.0" newVersion="4.0.5.0" />
      </dependentAssembly>
    </assemblyBinding>
  </runtime>
</configuration>
