<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Tema oscuro Odin (MD3 + shell tipo Ares). -->
    <Color x:Key="AresBackgroundColor">#2210161D</Color>
    <Color x:Key="AresSurfaceColor">#6B111827</Color>
    <Color x:Key="AresPanelColor">#55161B22</Color>
    <Color x:Key="AresAccentColor">#c0cfcb</Color>
    <Color x:Key="AresAccentHoverColor">#c0cfcb</Color>
    <Color x:Key="AresActionBlueColor">#2196F3</Color>
    <Color x:Key="AresActionBlueHoverColor">#1976D2</Color>
    <Color x:Key="AresTextColor">#F8F9FA</Color>
    <Color x:Key="AresMutedTextColor">#D1D5DB</Color>
    <Color x:Key="AresErrorColor">#FF6B6B</Color>
    <Color x:Key="AresSuccessColor">#10B981</Color>
    <Color x:Key="AresReadyColor">#6EE7B7</Color>
    <Color x:Key="AresFileTextColor">#64B5F6</Color>
    <Color x:Key="AresSlotAccentColor">#9CA3AF</Color>
    <Color x:Key="AresClearColor">#E57373</Color>

    <SolidColorBrush x:Key="PrimaryHueDarkBrush" Color="{StaticResource AresBackgroundColor}"/>
    <SolidColorBrush x:Key="PrimaryHueDarkForegroundBrush" Color="{StaticResource AresTextColor}"/>
    <SolidColorBrush x:Key="PrimaryHueLightBrush" Color="{StaticResource AresPanelColor}"/>
    <SolidColorBrush x:Key="PrimaryHueLightForegroundBrush" Color="{StaticResource AresTextColor}"/>
    <SolidColorBrush x:Key="PrimaryHueMidBrush" Color="{StaticResource AresSurfaceColor}"/>
    <SolidColorBrush x:Key="PrimaryHueMidForegroundBrush" Color="{StaticResource AresTextColor}"/>
    <SolidColorBrush x:Key="SecondaryHueLightBrush" Color="{StaticResource AresAccentColor}"/>
    <SolidColorBrush x:Key="SecondaryHueLightForegroundBrush" Color="{StaticResource AresBackgroundColor}"/>
    <SolidColorBrush x:Key="SecondaryHueDarkBrush" Color="{StaticResource AresAccentHoverColor}"/>
    <SolidColorBrush x:Key="SecondaryHueDarkForegroundBrush" Color="{StaticResource AresBackgroundColor}"/>
    <SolidColorBrush x:Key="TabColorBrush" Color="{StaticResource AresPanelColor}"/>
    <SolidColorBrush x:Key="TabColorForegroundBrush" Color="{StaticResource AresMutedTextColor}"/>

    <SolidColorBrush x:Key="ActionBlueBrush" Color="{StaticResource AresActionBlueColor}"/>
    <SolidColorBrush x:Key="ActionBlueHoverBrush" Color="{StaticResource AresActionBlueHoverColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource AresErrorColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource AresSuccessColor}"/>
    <SolidColorBrush x:Key="ReadyBrush" Color="{StaticResource AresReadyColor}"/>
    <SolidColorBrush x:Key="FileTextBrush" Color="{StaticResource AresFileTextColor}"/>
    <SolidColorBrush x:Key="SlotAccentBrush" Color="{StaticResource AresSlotAccentColor}"/>
    <SolidColorBrush x:Key="ClearAccentBrush" Color="{StaticResource AresClearColor}"/>
    <SolidColorBrush x:Key="AresCardBrush" Color="#3D161B22"/>
    <SolidColorBrush x:Key="AresInputBrush" Color="#3310161D"/>
    <SolidColorBrush x:Key="AresSoftBorderBrush" Color="#4400FFC6"/>
    <SolidColorBrush x:Key="ShellBackgroundBrush" Color="#CC10161D"/>
    <SolidColorBrush x:Key="AresTitleBarBrush" Color="#FF1A2332"/>
    <SolidColorBrush x:Key="AresTitleBarAccentBrush" Color="#FF00FFC6"/>

    <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="{StaticResource AresTextColor}"/>
    <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="{StaticResource AresMutedTextColor}"/>
    <SolidColorBrush x:Key="TextFillColorTertiaryBrush" Color="{StaticResource AresMutedTextColor}"/>
    <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush" Color="#3D161B22"/>
    <SolidColorBrush x:Key="CardStrokeColorDefaultBrush" Color="#4400FFC6"/>
    <SolidColorBrush x:Key="ApplicationBackgroundBrush" Color="#FF10161D"/>

    <DropShadowEffect x:Key="AresCardShadow"
                      BlurRadius="18"
                      ShadowDepth="0"
                      Color="#AA000000"
                      Opacity="0.28"/>

    <DropShadowEffect x:Key="AresAccentGlow"
                      BlurRadius="18"
                      ShadowDepth="0"
                      Color="{StaticResource AresAccentColor}"
                      Opacity="0.18"/>

    <DropShadowEffect x:Key="OdinShellShadow"
                      Color="Black"
                      Direction="270"
                      ShadowDepth="10"
                      Opacity="0.35"
                      BlurRadius="20"/>

    <Style x:Key="OdinPanelBorder" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource AresCardBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource AresSoftBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <Style x:Key="OdinTitleBarButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryHueDarkForegroundBrush}"/>
        <Setter Property="Width" Value="36"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="OdinActionButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource ActionBlueBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="MinHeight" Value="30"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource ActionBlueHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.85"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.35"/>
                            <Setter Property="Cursor" Value="Arrow"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource AresInputBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryHueDarkForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource AresSoftBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,5"/>
        <Setter Property="CaretBrush" Value="{StaticResource SecondaryHueLightBrush}"/>
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource AresInputBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryHueDarkForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource AresSoftBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="MinHeight" Value="34"/>
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource PrimaryHueDarkForegroundBrush}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style TargetType="GroupBox">
        <Setter Property="Foreground" Value="{StaticResource SecondaryHueLightBrush}"/>
        <Setter Property="BorderBrush" Value="#3300FFC6"/>
        <Setter Property="Background" Value="{StaticResource TabColorBrush}"/>
        <Setter Property="Padding" Value="8"/>
    </Style>

    <Style x:Key="OdinFlashProgressBar" TargetType="ProgressBar">
        <Setter Property="Foreground" Value="{StaticResource ActionBlueBrush}"/>
        <Setter Property="Background" Value="#332196F3"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style TargetType="ProgressBar" BasedOn="{StaticResource OdinFlashProgressBar}"/>
</ResourceDictionary>
