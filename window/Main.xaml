<Window x:Class="Odin_Flash.window.Main"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Odin_Flash.window"
        Loaded="Window_Loaded"
        WindowStartupLocation="CenterScreen"
        Title="Odin Flash" Height="550" Width="900"
        MinHeight="420"
        MinWidth="760"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Border Margin="10"
            CornerRadius="10"
            Background="{DynamicResource PrimaryHueMidBrush}"
            Effect="{StaticResource AresCardShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0"
                    Background="{DynamicResource PrimaryHueDarkBrush}"
                    BorderThickness="0"
                    CornerRadius="10,10,0,0"
                    Padding="14,10"
                    MouseMove="Grid_MouseMove">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="12"
                                Height="12"
                                CornerRadius="6"
                                Background="{DynamicResource SecondaryHueLightBrush}"
                                Effect="{StaticResource AresAccentGlow}"
                                Margin="0,0,10,0"/>
                        <Label Content="Odin Flash"
                               VerticalAlignment="Center"
                               FontSize="15"
                               FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryHueDarkForegroundBrush}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Column="1">
                        <Button x:Name="BtnMinMaxWindow"
                                Style="{StaticResource WindowControlButtonStyle}"
                                Click="BtnMinMaxWindow_Click"
                                Content="─"
                                Margin="2"/>
                        <Button x:Name="BtnMinMaximizeWindow"
                                Style="{StaticResource WindowControlButtonStyle}"
                                Click="BtnMinMaximizeWindow_Click"
                                Content="□"
                                Margin="2"/>
                        <Button x:Name="BtnClose"
                                Style="{StaticResource CloseWindowButtonStyle}"
                                Click="BtnClose_Click"
                                Content="×"
                                Margin="2"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"
                        CornerRadius="10"
                        Background="{DynamicResource PrimaryHueLightBrush}"
                        Margin="0,0,5,0"
                        Padding="8">
                    <Frame Name="FrmMain"
                           Background="Transparent"
                           NavigationUIVisibility="Hidden"/>
                </Border>
                <Grid Grid.Column="1" Margin="5,0,0,0">
                    <GroupBox Grid.Column="1"
                              Header="Log"
                              Name="GrpBxLog"
                              Background="{DynamicResource TabColorBrush}"
                              Margin="0">
                        <RichTextBox Block.LineHeight="1"
                                     TextChanged="RichLog_TextChanged"
                                     Background="{DynamicResource TabColorBrush}"
                                     Foreground="{DynamicResource TabColorForegroundBrush}"
                                     BorderThickness="0"
                                     IsReadOnly="True"
                                     HorizontalScrollBarVisibility="Auto"
                                     VerticalScrollBarVisibility="Auto"
                                     x:Name="RichLog"
                                     Margin="0"
                                     FontFamily="Courier New">

                        </RichTextBox>

                    </GroupBox>
                    <Button Name="BtnClearRich"
                            VerticalAlignment="Top"
                            Click="BtnClearRich_Click"
                            Margin="0,10,9,0"
                            HorizontalAlignment="Right"
                            Content="Clear"
                            Width="58"
                            Height="28"/>
                </Grid>
            </Grid>

            <Border Grid.Row="2"
                    Margin="10,0,10,10"
                    Padding="10,6"
                    CornerRadius="10"
                    Background="{DynamicResource PrimaryHueLightBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>
                    <ProgressBar Grid.Row="0"
                             Name="ProgBar"
                             Value="0"
                             Margin="0,2,0,6"/>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>
                        <Label Name="ConnectedName"
                               Grid.Column="0"
                               Content="Disconnected"
                               Margin="0,4,12,0"
                               Foreground="{DynamicResource ErrorBrush}"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                        <Label Name="Events"
                               Grid.Column="1"
                               Content="Ready"
                               Margin="0,4,12,0"
                               Foreground="{DynamicResource TabColorForegroundBrush}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2"
                                   Margin="5,4,8,0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TabColorForegroundBrush}">
                            <Hyperlink NavigateUri="https://phone-parts.pages.dev/dashboard"
                                       RequestNavigate="PhonePartsLink_RequestNavigate">
                                https://phone-parts.pages.dev/dashboard
                            </Hyperlink>
                        </TextBlock>
                        <Button x:Name="BtnStop"
                                IsEnabled="False"
                                Grid.Column="3"
                                Margin="5,3,0,0"
                                Click="BtnStop_Click"
                                Content="Stop"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
