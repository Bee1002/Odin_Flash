<ui:FluentWindow x:Class="Odin_Flash.window.Main"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:local="clr-namespace:Odin_Flash.window"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Loaded="Window_Loaded"
                 WindowStartupLocation="CenterScreen"
                 Title="Odin Flash" Height="550" Width="900"
                 MinHeight="420"
                 MinWidth="760"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Acrylic"
                 WindowCornerPreference="Round"
                 Background="Transparent">
    <Border Margin="10"
            CornerRadius="10"
            Background="{DynamicResource PrimaryHueMidBrush}"
            Effect="{StaticResource AresCardShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>
            <ui:TitleBar Grid.Row="0"
                         Title="Odin Flash"
                         ForceShutdown="True"
                         ShowMinimize="True"
                         ShowMaximize="True"
                         ShowClose="True"
                         Background="{DynamicResource PrimaryHueDarkBrush}"
                         Foreground="{DynamicResource PrimaryHueDarkForegroundBrush}"
                         ButtonsForeground="{DynamicResource PrimaryHueDarkForegroundBrush}"
                         ButtonsBackground="Transparent">
                <ui:TitleBar.Header>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="12"
                                Height="12"
                                CornerRadius="6"
                                Background="{DynamicResource SecondaryHueLightBrush}"
                                Effect="{StaticResource AresAccentGlow}"
                                Margin="0,0,10,0"/>
                        <ui:TextBlock Text="Odin Flash"
                                      VerticalAlignment="Center"
                                      FontTypography="BodyStrong"
                                      Foreground="{DynamicResource PrimaryHueDarkForegroundBrush}"/>
                    </StackPanel>
                </ui:TitleBar.Header>
            </ui:TitleBar>

            <Grid Grid.Row="1" Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <ui:Card Grid.Column="0"
                         Background="{DynamicResource PrimaryHueLightBrush}"
                         Margin="0,0,5,0"
                         Padding="8">
                    <Frame Name="FrmMain"
                           Background="Transparent"
                           NavigationUIVisibility="Hidden"/>
                </ui:Card>
                <Grid Grid.Column="1" Margin="5,0,0,0">
                    <ui:Card Grid.Column="1"
                             Name="GrpBxLog"
                             Background="{DynamicResource TabColorBrush}"
                             Padding="10"
                             Margin="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <ui:TextBlock Grid.Row="0"
                                          Text="Log"
                                          FontTypography="BodyStrong"
                                          Foreground="{DynamicResource SecondaryHueLightBrush}"
                                          Margin="0,0,0,8"/>
                            <ui:RichTextBox Grid.Row="1"
                                            Block.LineHeight="1"
                                            TextChanged="RichLog_TextChanged"
                                            Background="Transparent"
                                            Foreground="{DynamicResource TabColorForegroundBrush}"
                                            BorderThickness="0"
                                            IsReadOnly="True"
                                            HorizontalScrollBarVisibility="Auto"
                                            VerticalScrollBarVisibility="Auto"
                                            x:Name="RichLog"
                                            Margin="0"
                                            FontFamily="Courier New"/>
                        </Grid>
                    </ui:Card>
                    <ui:Button Name="BtnClearRich"
                               Appearance="Secondary"
                               VerticalAlignment="Top"
                               Click="BtnClearRich_Click"
                               Margin="0,10,9,0"
                               HorizontalAlignment="Right"
                               Content="Clear"
                               Width="58"
                               Height="28">
                        <ui:Button.Icon>
                            <ui:SymbolIcon Symbol="Delete16"/>
                        </ui:Button.Icon>
                    </ui:Button>
                </Grid>
            </Grid>

            <ui:Card Grid.Row="2"
                     Margin="10,0,10,10"
                     Padding="10,6"
                     Background="{DynamicResource PrimaryHueLightBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>
                    <ProgressBar Grid.Row="0"
                             Name="ProgBar"
                             Value="0"
                             Margin="0,2,0,6"/>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>
                        <ui:TextBlock Name="ConnectedName"
                                      Grid.Column="0"
                                      Text="Disconnected"
                                      Margin="0,4,12,0"
                                      Foreground="{DynamicResource ErrorBrush}"
                                      FontTypography="BodyStrong"
                                      VerticalAlignment="Center"/>
                        <ui:TextBlock Name="Events"
                                      Grid.Column="1"
                                      Text="Ready"
                                      Margin="0,4,12,0"
                                      Foreground="{DynamicResource TabColorForegroundBrush}"
                                      FontTypography="BodyStrong"
                                      VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2"
                                   Margin="5,4,8,0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TabColorForegroundBrush}">
                            <Hyperlink NavigateUri="https://phone-parts.pages.dev/dashboard"
                                       RequestNavigate="PhonePartsLink_RequestNavigate">
                                https://phone-parts.pages.dev/dashboard
                            </Hyperlink>
                        </TextBlock>
                        <ui:Button x:Name="BtnStop"
                                   Appearance="Danger"
                                   IsEnabled="False"
                                   Grid.Column="3"
                                   Margin="5,3,0,0"
                                   Click="BtnStop_Click"
                                   Content="Stop">
                            <ui:Button.Icon>
                                <ui:SymbolIcon Symbol="DismissCircle12"/>
                            </ui:Button.Icon>
                        </ui:Button>
                    </Grid>
                </Grid>
            </ui:Card>
        </Grid>
    </Border>
</ui:FluentWindow>
