<UserControl x:Class="Odin_Flash.Controls.Flash"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Odin_Flash.Controls"
             mc:Ignorable="d"
             TextElement.Foreground="{DynamicResource PrimaryHueDarkForegroundBrush}"
             Background="Transparent"
             d:DesignWidth="500">
    <!-- Misma estructura funcional que Freya.Controls.Flash; estilo visual Material-like con recursos del tema. -->
    <Grid Background="Transparent">
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Firmware"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryHueDarkForegroundBrush}"/>
                </StackPanel>
            </Grid>

            <StackPanel x:Name="Features" Grid.Row="1" Orientation="Vertical" Margin="0,0,0,2">
            </StackPanel>

            <Expander Grid.Row="2"
                      Header="Opciones avanzadas"
                      Foreground="{DynamicResource TabColorForegroundBrush}"
                      Margin="0,0,0,8"
                      IsExpanded="False">
                <StackPanel Margin="0,6,0,0">
                    <Border CornerRadius="10"
                            Background="{DynamicResource AresCardBrush}"
                            BorderBrush="{DynamicResource AresSoftBorderBrush}"
                            BorderThickness="1"
                            Padding="10"
                            Margin="0,0,0,6">
                        <Grid x:Name="Pit">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="PIT"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource SecondaryHueLightBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"/>
                            <TextBox Grid.Column="1"
                                     Text=""
                                     IsReadOnly="True"
                                     VerticalAlignment="Center"
                                     Margin="0,0,8,0"
                                     AcceptsReturn="False"
                                     Name="TxtBxPit"
                                     TextChanged="TxtBxPit_TextChanged"
                                     ToolTip="PIT File"/>
                            <Button x:Name="BtnClearPit"
                                    Click="BtnClearPit_Click"
                                    Margin="0,0,6,0"
                                    Grid.Column="2"
                                    Content="Clear"
                                    MinWidth="58"/>
                            <Button x:Name="BtnChoosePit"
                                    Click="BtnChoosePit_Click"
                                    Grid.Column="3"
                                    Content="Load PIT"
                                    MinWidth="82"/>
                        </Grid>
                    </Border>
                    <Border CornerRadius="10"
                            Background="{DynamicResource AresCardBrush}"
                            BorderBrush="{DynamicResource AresSoftBorderBrush}"
                            BorderThickness="1"
                            Padding="8">
                        <WrapPanel Orientation="Horizontal">
                            <CheckBox Content="Auto reboot"
                                      Name="AutoBoot"
                                      Margin="6"
                                      IsChecked="True"/>
                            <CheckBox Name="RepartitionCheckBx"
                                      Content="Repartition"
                                      Margin="6"
                                      IsChecked="False"
                                      Foreground="{DynamicResource PrimaryHueDarkForegroundBrush}"/>
                            <CheckBox Content="Update boot"
                                      x:Name="BootUpdate"
                                      Margin="6"/>
                            <CheckBox Content="Clear EFS"
                                      x:Name="EfsClear"
                                      Margin="6"/>
                        </WrapPanel>
                    </Border>
                </StackPanel>
            </Expander>

            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>
                <Button Margin="0,0,8,0"
                        Grid.Column="0"
                        Name="BtnFlash"
                        Click="BtnFlash_Click"
                        Style="{DynamicResource PrimaryActionButtonStyle}">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                        <TextBlock Name="LblFastFlash"
                                   Text="Flash"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Margin="5"
                        Grid.Column="1"
                        Name="BtnReadPit"
                        Click="BtnReadPit_Click"
                        Style="{DynamicResource SecondaryActionButtonStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Name="LblReadPit"
                                   Text="Read PIT"
                                   Margin="5"
                                   Grid.Column="0"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Button>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
