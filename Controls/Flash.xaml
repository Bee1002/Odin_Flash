<UserControl x:Class="Odin_Flash.Controls.Flash"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             TextElement.Foreground="{DynamicResource PrimaryHueDarkForegroundBrush}"
             Background="Transparent"
             AllowDrop="True"
             DragOver="Flash_DragOver"
             Drop="Flash_Drop"
             d:DesignWidth="500">
    <Grid Background="Transparent">
        <Grid Margin="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Firmware"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Margin="0,0,0,4"
                       Foreground="{DynamicResource PrimaryHueDarkForegroundBrush}"/>

            <Grid x:Name="Features"
                  Grid.Row="1"
                  Margin="0,0,0,6"
                  VerticalAlignment="Top">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
            </Grid>

            <Expander Grid.Row="2"
                      Header="Opciones avanzadas"
                      Foreground="{DynamicResource TabColorForegroundBrush}"
                      Margin="0,0,0,6"
                      IsExpanded="False">
                <StackPanel Margin="0,6,0,0">
                    <Border Style="{StaticResource OdinPanelBorder}"
                            Padding="8"
                            Margin="0,0,0,4">
                        <Grid x:Name="Pit">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="PIT"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource SecondaryHueLightBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"/>
                            <TextBox Grid.Column="1"
                                     IsReadOnly="True"
                                     VerticalAlignment="Center"
                                     Margin="0,0,8,0"
                                     Name="TxtBxPit"
                                     TextChanged="TxtBxPit_TextChanged"
                                     ToolTip="PIT File"/>
                            <Button x:Name="BtnClearPit"
                                    Style="{StaticResource OdinClearOutlinedButton}"
                                    Click="BtnClearPit_Click"
                                    Margin="0,0,6,0"
                                    Grid.Column="2"
                                    MinWidth="58"
                                    Padding="8,4">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Delete" Width="16" Height="16" VerticalAlignment="Center"/>
                                    <TextBlock Text="Clear" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="BtnChoosePit"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Click="BtnChoosePit_Click"
                                    Grid.Column="3"
                                    MinWidth="82"
                                    Padding="8,4">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="FilePlus" Width="16" Height="16" VerticalAlignment="Center"/>
                                    <TextBlock Text="Load PIT" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource OdinPanelBorder}" Padding="8">
                        <WrapPanel Orientation="Horizontal">
                            <ToggleButton Content="Auto reboot"
                                          Name="AutoBoot"
                                          Margin="6"
                                          IsChecked="True"
                                          Style="{StaticResource MaterialDesignSwitchToggleButton}"/>
                            <ToggleButton Name="RepartitionCheckBx"
                                          Content="Repartition"
                                          Margin="6"
                                          IsChecked="False"
                                          Style="{StaticResource MaterialDesignSwitchToggleButton}"/>
                            <ToggleButton Content="Update boot"
                                          x:Name="BootUpdate"
                                          Margin="6"
                                          Style="{StaticResource MaterialDesignSwitchToggleButton}"/>
                            <ToggleButton Content="Clear EFS"
                                          x:Name="EfsClear"
                                          Margin="6"
                                          Style="{StaticResource MaterialDesignSwitchToggleButton}"/>
                        </WrapPanel>
                    </Border>
                </StackPanel>
            </Expander>
        </Grid>
    </Grid>
</UserControl>
