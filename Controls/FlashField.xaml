<UserControl x:Class="Odin_Flash.Controls.FlashField"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Odin_Flash.Controls"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
             VerticalAlignment="Stretch">
    <ui:Card Background="{DynamicResource AresCardBrush}"
             BorderBrush="{DynamicResource AresSoftBorderBrush}"
             BorderThickness="1"
             Padding="6,4"
             Margin="0,0,0,2"
             VerticalAlignment="Stretch">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0">
                <ComboBox SelectionChanged="CmbBxListFile_SelectionChanged"
                          Name="CmbBxListFile"
                          SelectedValue="{Binding FilePath}"
                          Margin="0,0,6,0"
                          MinHeight="28"
                          VerticalContentAlignment="Center"
                          Padding="6,2">
                    <ComboBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel IsVirtualizing="True" VirtualizationMode="Recycling"/>
                        </ItemsPanelTemplate>
                    </ComboBox.ItemsPanel>
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding Enable}"
                                      Content="{Binding FileName}"
                                      Foreground="{DynamicResource FileTextBrush}"
                                      FontWeight="SemiBold"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>

                </ComboBox>
                <ui:TextBlock Foreground="{DynamicResource FileTextBrush}"
                              IsHitTestVisible="False"
                              Margin="10,0,18,0"
                              Name="txtSelectTeam"
                              FontTypography="Caption"
                              FontWeight="SemiBold"
                              VerticalAlignment="Center"/>
            </Grid>


            <ui:Button x:Name="BtnClear"
                       Appearance="Secondary"
                       Click="BtnClear_Click"
                       Margin="0,0,6,0"
                       Grid.Column="1"
                       Content="Clear"
                       Width="72"
                       MinWidth="72"
                       MinHeight="28"
                       Padding="8,4">
                <ui:Button.Icon>
                    <ui:SymbolIcon Symbol="Delete16"/>
                </ui:Button.Icon>
            </ui:Button>
            <ui:Button x:Name="BtnChooseFile"
                       Appearance="Secondary"
                       Click="BtnChooseFile_Click"
                       Grid.Column="2"
                       Content="Browse"
                       Width="120"
                       MinWidth="120"
                       MinHeight="28"
                       Padding="10,4">
                <ui:Button.Icon>
                    <ui:SymbolIcon Symbol="FolderOpen16"/>
                </ui:Button.Icon>
            </ui:Button>
        </Grid>
    </ui:Card>
</UserControl>
